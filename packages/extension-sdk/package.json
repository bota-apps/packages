{
  "name": "@bota-apps/extension-sdk",
  "version": "0.2.17",
  "description": "The runtime contract for embeddable @bota-apps extension apps: the host↔iframe bridge (isEmbedded/notifyHost, install-context parsing), the standalone ExtensionShell chrome, and createExtensionApp — the bootstrap factory that renders an extension bare when embedded in a host and shell-wrapped when run standalone.",
  "keywords": [
    "bota-apps",
    "typescript",
    "iframe",
    "embed",
    "extension",
    "postmessage",
    "sdk",
    "react"
  ],
  "license": "MIT",
  "author": {
    "name": "Bota Apps",
    "url": "https://github.com/bota-apps"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc && node ../../scripts/fixExtensions.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bota-apps/packages.git",
    "directory": "packages/extension-sdk"
  },
  "homepage": "https://github.com/bota-apps/packages/tree/main/packages/extension-sdk#readme",
  "bugs": {
    "url": "https://github.com/bota-apps/packages/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bota-apps/react-ui": "workspace:^",
    "lucide-react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  }
}
