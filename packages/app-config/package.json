{
  "name": "@bota-apps/app-config",
  "version": "0.2.0",
  "description": "Standardized runtime env config for @bota-apps apps: createViteAppConfig (maps Vite VITE_* env vars onto a Zod schema, failing fast on missing/invalid values), graphqlAppEnv — the base env schema every GraphQL-backed host shares (mode, apiUrl, authUrl, baseDomains, session gateway paths) — and sessionPaths, which maps the session env keys onto the auth-client paths shape. Apps extend the base with app-only keys.",
  "keywords": [
    "bota-apps",
    "typescript",
    "config",
    "env",
    "vite",
    "zod",
    "graphql",
    "schema"
  ],
  "license": "MIT",
  "author": {
    "name": "Bota Apps",
    "url": "https://github.com/bota-apps"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc && node ../../scripts/fixExtensions.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bota-apps/packages.git",
    "directory": "packages/app-config"
  },
  "homepage": "https://github.com/bota-apps/packages/tree/main/packages/app-config#readme",
  "bugs": {
    "url": "https://github.com/bota-apps/packages/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  }
}
